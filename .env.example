# ─── The Screen Age — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values

# Site domain (no protocol, no trailing slash)
SITE_DOMAIN=thescreenage.com

# Site URL (with protocol)
SITE_URL=https://thescreenage.com

# Port for the Express server
PORT=3000

# Node environment
NODE_ENV=production

# OpenAI API key (for article generation)
# Used by scripts/fast-seed.mjs and scripts/cron-generate.mjs
OPENAI_API_KEY=sk-...

# Bunny CDN (add when ready)
# BUNNY_API_KEY=your-bunny-api-key
# BUNNY_STORAGE_ZONE=the-screen-age
# BUNNY_PULL_ZONE=https://the-screen-age.b-cdn.net
