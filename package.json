{
  "name": "screentoxic",
  "version": "1.0.0",
  "description": "Evidence-based, non-alarmist resource on kids and technology, screen time, and the anxious generation.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.mjs",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.mjs",
    "seed": "node scripts/seed.mjs",
    "cron:publish": "node scripts/cron-publish.mjs",
    "cron:generate": "node scripts/cron-generate.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "compression": "^1.7.4",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "openai": "^4.47.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "vite-plugin-ssr": "^0.4.142"
  }
}
